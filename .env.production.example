# Production Environment Configuration (NO DOMAIN VERSION)
# Copy this file to .env and fill in the actual values

# ============================================
# DATABASE CONFIGURATION (MySQL di VPS)
# ============================================
DB_HOST=localhost
DB_USER=skincare_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_123
DB_NAME=skincare_analyzer

# ============================================
# API KEYS & SECRETS
# ============================================
# Generate dengan: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_JWT_SECRET_KEY_HERE

# Gemini AI API Key (dari Google AI Studio)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Monitoring API Key untuk dashboard admin
# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
MONITORING_API_KEY=YOUR_SECURE_MONITORING_KEY_HERE

# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Path ke Firebase Admin SDK JSON file
FIREBASE_CREDENTIALS_PATH=/home/skincare/skincare-analyzer-backend/dermify-e69de-firebase-adminsdk-fbsvc-eb6e0455ca.json

# ============================================
# APPLICATION SETTINGS
# ============================================
# Environment: production, staging, development
APP_ENV=production

# Enable/disable debug mode (MUST be false in production)
DEBUG=false

# Allowed hosts (comma-separated) - Ganti YOUR_VPS_IP dengan IP VPS kamu
ALLOWED_HOSTS=YOUR_VPS_IP,localhost

# CORS origins (comma-separated, or * for all)
# Ganti YOUR_VPS_IP dengan IP VPS kamu
# Ganti your-dashboard.vercel.app dengan URL Vercel kamu
CORS_ORIGINS=http://YOUR_VPS_IP,https://your-dashboard.vercel.app,*

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=/home/skincare/skincare-analyzer-backend/logs/app.log

# ============================================
# RATE LIMITING (optional)
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ============================================
# FILE UPLOAD
# ============================================
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/home/skincare/skincare-analyzer-backend/uploads

# ============================================
# EXTERNAL SERVICES
# ============================================
# Tesseract OCR path (biasanya auto-detect)
TESSERACT_CMD=/usr/bin/tesseract
